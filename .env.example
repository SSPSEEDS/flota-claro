# Variables de entorno de la app Flota Claro.
# En EasyPanel se cargan en la pestana "Environment" del servicio (no se sube el .env al repo).

# Cadena de conexion a PostgreSQL (la da EasyPanel al crear el servicio de base de datos).
# Formato: postgres://USUARIO:CLAVE@HOST:5432/NOMBRE_BASE
DATABASE_URL=postgres://flota:cambiar-clave@flota-db:5432/flota

# Si la base exige SSL (bases externas/administradas), poner 1. En la red interna de EasyPanel: dejar vacio.
PGSSL=

# Clave secreta para firmar las cookies de sesion. Generar una larga y aleatoria.
SESSION_SECRET=pega-aca-una-cadena-larga-y-aleatoria

# Admin inicial: se crea automaticamente la primera vez si todavia no hay usuarios.
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Entorno (en produccion: production -> cookies seguras por HTTPS).
NODE_ENV=production
PORT=3000
